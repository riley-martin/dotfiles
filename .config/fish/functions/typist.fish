function typist
    for i in h e l l o , ' ' w o r l d
        printf $i
        sleep 0.2
    end
    printf '\r'
    for i in (seq 0 12)
        printf ' '
    end
    printf '\r'
    sleep 1
    for i in h o w ' ' a r e ' ' y o u '?'
        printf $i
        sleep 0.2
    end
    sleep 2
    printf '\n'
end
